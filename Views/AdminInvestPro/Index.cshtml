@model List<InvestProItem>
@{
    ViewData["Title"] = "InvestPro";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h4 class="mb-0">InvestPro</h4>
    <a asp-action="Create" class="btn btn-primary btn-sm">
        <i class="bi bi-plus-lg"></i> New InvestPro
    </a>
</div>

@if (TempData["Success"] is string ok)
{
    <div class="alert alert-success py-2">@ok</div>
}

<div class="card shadow-sm">
    <div class="card-body p-0">
        <table class="table table-hover mb-0 align-middle">
            <thead class="table-light">
                <tr>
                    <th>Title</th>
                    <th>Description</th>
                    <th>Status</th>
                    <th>Created</th>
                    <th class="text-end" style="width:160px">Actions</th>
                </tr>
            </thead>
            <tbody>
                @if (!Model.Any())
                {
                    <tr><td colspan="5" class="text-center text-muted py-4">No investpro items yet.</td></tr>
                }
                @foreach (var x in Model)
                {
                    <tr data-row-id="@x.Id">
                        <td class="fw-medium">@x.Title</td>
                        <td class="text-muted">@(x.Description.Length > 80 ? x.Description[..80] + "…" : x.Description)</td>
                        <td>
                            @if (x.IsPublished)
                            {
                                <span class="badge text-bg-success">Published</span>
                            }
                            else
                            {
                                <span class="badge text-bg-secondary">Draft</span>
                            }
                        </td>
                        <td class="text-muted small">@x.CreatedAt.ToString("yyyy-MM-dd HH:mm")</td>
                        <td class="text-end">
                            <a asp-action="Edit" asp-route-id="@x.Id" class="btn btn-sm btn-outline-secondary">
                                <i class="bi bi-pencil"></i>
                            </a>
                            <button type="button" class="btn btn-sm btn-outline-danger"
                                    data-fcms-action="delete"
                                    data-url="/admin/investpro/@x.Id/delete"
                                    data-confirm-title="Delete?"
                                    data-confirm-message="@x.Title"
                                    data-confirm-variant="danger"
                                    data-confirm-label="Delete">
                                <i class="bi bi-trash"></i>
                            </button>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
