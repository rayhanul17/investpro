@model List<ApprovalConfig>
@{
    ViewData["Title"] = "Approval Configuration";
    Layout = "_InvestProLayout";
}

<div class="mb-3">
    <h4 class="mb-1">Approval Configuration</h4>
    <small class="text-muted">
        Set per-ledger thresholds. Entries with amount below <strong>Auto-approve below</strong> are activated instantly.
        Above <strong>Require approval above</strong> need approver action. Above <strong>Require all partners above</strong>,
        every partner of the investment must approve.
    </small>
</div>

@if (TempData["Success"] is string ok)
{
    <div class="alert alert-success py-2">@ok</div>
}
@if (TempData["Error"] is string err)
{
    <div class="alert alert-danger py-2">@err</div>
}

<form method="post" action="/investpro/admin/approval-config/save">
    @Html.AntiForgeryToken()
    <div class="card shadow-sm">
        <div class="card-body p-0">
            <table class="table mb-0 align-middle">
                <thead class="table-light">
                    <tr>
                        <th style="width:140px">Ledger</th>
                        <th>Auto-approve below (BDT)</th>
                        <th>Require approval above (BDT)</th>
                        <th>Require all partners above (BDT)</th>
                        <th style="width:200px">Approver Role</th>
                    </tr>
                </thead>
                <tbody>
                    @for (int i = 0; i < Model.Count; i++)
                    {
                        var row = Model[i];
                        <tr>
                            <td class="fw-medium">@row.LedgerType</td>
                            <td>
                                <input type="hidden" name="rows[@i].Id" value="@row.Id" />
                                <input type="number" step="0.01" min="0" class="form-control form-control-sm" name="rows[@i].AutoApproveBelow" value="@row.AutoApproveBelow" />
                            </td>
                            <td>
                                <input type="number" step="0.01" min="0" class="form-control form-control-sm" name="rows[@i].RequireApprovalAbove" value="@row.RequireApprovalAbove" />
                            </td>
                            <td>
                                <input type="number" step="0.01" min="0" class="form-control form-control-sm" name="rows[@i].RequireAllPartnersAbove" value="@row.RequireAllPartnersAbove" />
                            </td>
                            <td>
                                <select class="form-select form-select-sm" name="rows[@i].ApproverRole">
                                    @foreach (var r in Enum.GetValues<ApproverRole>())
                                    {
                                        if (r == row.ApproverRole)
                                        {
                                            <option value="@r" selected>@r</option>
                                        }
                                        else
                                        {
                                            <option value="@r">@r</option>
                                        }
                                    }
                                </select>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
    <div class="mt-3">
        <button type="submit" class="btn btn-primary">Save Changes</button>
    </div>
</form>
