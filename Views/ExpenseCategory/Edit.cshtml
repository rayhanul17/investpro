@model ExpenseCategory
@{
    var isNew = ViewData["IsNew"] as bool? ?? Model.Id == Guid.Empty;
    ViewData["Title"] = isNew ? "New Category" : "Edit Category";
    Layout = "_AdminLayout";
    var formAction = isNew ? "/admin/investpro/expense-categories/create" : $"/admin/investpro/expense-categories/{Model.Id}/edit";
}

<div class="d-flex align-items-center mb-3 gap-2">
    <a asp-action="Index" class="btn btn-sm btn-outline-secondary">← Back</a>
    <h4 class="mb-0">@ViewData["Title"]</h4>
    @if (Model.IsSystem)
    {
        <span class="badge text-bg-warning ms-2"><i class="bi bi-lock"></i> System</span>
    }
</div>

<form method="post" action="@formAction">
    @Html.AntiForgeryToken()
    <div asp-validation-summary="ModelOnly" class="alert alert-danger" role="alert"></div>

    <div class="card shadow-sm">
        <div class="card-body">
            <div class="row g-3">
                <div class="col-md-8">
                    <label asp-for="Name" class="form-label">Name <span class="text-danger">*</span></label>
                    <input asp-for="Name" class="form-control" required />
                    <span asp-validation-for="Name" class="text-danger small"></span>
                </div>
                <div class="col-md-4">
                    <label asp-for="SortOrder" class="form-label">Sort Order</label>
                    <input asp-for="SortOrder" type="number" class="form-control" />
                </div>
                <div class="col-12">
                    <label asp-for="Description" class="form-label">Description</label>
                    <textarea asp-for="Description" class="form-control" rows="3"></textarea>
                </div>
                <div class="col-12">
                    <div class="form-check">
                        <input asp-for="IsActive" class="form-check-input" />
                        <label asp-for="IsActive" class="form-check-label">Active</label>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="mt-3">
        <button type="submit" class="btn btn-primary">@(isNew ? "Create" : "Save Changes")</button>
        <a asp-action="Index" class="btn btn-outline-secondary ms-2">Cancel</a>
    </div>
</form>
