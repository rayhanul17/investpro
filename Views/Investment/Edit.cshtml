@model Investment
@{
    var isNew = ViewData["IsNew"] as bool? ?? Model.Id == Guid.Empty;
    ViewData["Title"] = isNew ? "New Investment" : "Edit Investment";
    Layout = "_InvestProLayout";
    var formAction = isNew ? "/investpro/admin/investments/create" : $"/investpro/admin/investments/{Model.Id}/edit";
}

<div class="d-flex align-items-center mb-3 gap-2">
    <a asp-action="Index" class="btn btn-sm btn-outline-secondary">← Back</a>
    <h4 class="mb-0">@ViewData["Title"]</h4>
</div>

<form method="post" action="@formAction">
    @Html.AntiForgeryToken()
    <div asp-validation-summary="ModelOnly" class="alert alert-danger" role="alert"></div>

    <div class="card shadow-sm mb-3">
        <div class="card-body">
            <div class="row g-3">
                <div class="col-md-4">
                    <label asp-for="Code" class="form-label">Code <span class="text-danger">*</span></label>
                    <input asp-for="Code" class="form-control" required />
                    <div class="form-text">Unique identifier. Suggested format <code>INV-YYYY-NNN</code>; override allowed.</div>
                    <span asp-validation-for="Code" class="text-danger small"></span>
                </div>
                <div class="col-md-8">
                    <label asp-for="Name" class="form-label">Name <span class="text-danger">*</span></label>
                    <input asp-for="Name" class="form-control" required />
                </div>
                <div class="col-md-4">
                    <label asp-for="StartDate" class="form-label">Start Date</label>
                    <input asp-for="StartDate" type="date" class="form-control" />
                </div>
                <div class="col-md-4">
                    <label asp-for="ExpectedEndDate" class="form-label">Expected End Date</label>
                    <input asp-for="ExpectedEndDate" type="date" class="form-control" />
                </div>
                <div class="col-12">
                    <label asp-for="Description" class="form-label">Description</label>
                    <textarea asp-for="Description" class="form-control" rows="3"></textarea>
                </div>
                <div class="col-12">
                    <label asp-for="Notes" class="form-label">Notes</label>
                    <textarea asp-for="Notes" class="form-control" rows="2"></textarea>
                </div>
            </div>
        </div>
    </div>

    <div class="mt-3">
        <button type="submit" class="btn btn-primary">@(isNew ? "Create Draft" : "Save Changes")</button>
        <a asp-action="Index" class="btn btn-outline-secondary ms-2">Cancel</a>
    </div>
</form>
