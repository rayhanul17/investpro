@model List<Investment>
@{
    ViewData["Title"] = "Investments";
    Layout = "_InvestProLayout";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <div>
        <h4 class="mb-0">Investments</h4>
        <small class="text-muted">All projects. Multiple parallel investments are allowed — each runs in its own isolated ledger.</small>
    </div>
    <a asp-action="Create" class="btn btn-primary btn-sm">
        <i class="bi bi-plus-lg"></i> New Investment
    </a>
</div>

@if (TempData["Success"] is string ok) { <div class="alert alert-success py-2">@ok</div> }
@if (TempData["Error"]   is string er) { <div class="alert alert-danger py-2">@er</div> }

<div class="card shadow-sm">
    <div class="card-body p-0">
        <table class="table table-hover mb-0 align-middle">
            <thead class="table-light">
                <tr>
                    <th style="width:160px">Code</th>
                    <th>Name</th>
                    <th style="width:120px">Status</th>
                    <th style="width:130px">Started</th>
                    <th style="width:130px">Closed</th>
                    <th class="text-end" style="width:140px">Actions</th>
                </tr>
            </thead>
            <tbody>
                @if (!Model.Any())
                {
                    <tr><td colspan="6" class="text-center text-muted py-4">No investments yet. Click <strong>New Investment</strong> to start.</td></tr>
                }
                @foreach (var inv in Model)
                {
                    <tr>
                        <td><a asp-action="Detail" asp-route-id="@inv.Id" class="fw-medium text-decoration-none">@inv.Code</a></td>
                        <td>@inv.Name</td>
                        <td>
                            @switch (inv.LifecycleStatus)
                            {
                                case InvestmentLifecycle.Draft:   <span class="badge text-bg-secondary">Draft</span>   break;
                                case InvestmentLifecycle.Active:  <span class="badge text-bg-success">Active</span>   break;
                                case InvestmentLifecycle.Closing: <span class="badge text-bg-warning">Closing</span>  break;
                                case InvestmentLifecycle.Closed:  <span class="badge text-bg-dark">Closed</span>      break;
                            }
                        </td>
                        <td class="text-muted small">@inv.StartDate.ToString("yyyy-MM-dd")</td>
                        <td class="text-muted small">@(inv.ClosedAt?.ToString("yyyy-MM-dd") ?? "—")</td>
                        <td class="text-end">
                            <a asp-action="Detail" asp-route-id="@inv.Id" class="btn btn-sm btn-outline-secondary">
                                <i class="bi bi-eye"></i>
                            </a>
                            @if (inv.LifecycleStatus == InvestmentLifecycle.Draft)
                            {
                                <a asp-action="Edit" asp-route-id="@inv.Id" class="btn btn-sm btn-outline-secondary">
                                    <i class="bi bi-pencil"></i>
                                </a>
                                <button type="button" class="btn btn-sm btn-outline-danger"
                                        data-fcms-action="delete"
                                        data-url="/investpro/admin/investments/@inv.Id/delete"
                                        data-confirm-title="Delete draft?"
                                        data-confirm-message="@inv.Code — @inv.Name"
                                        data-confirm-variant="danger"
                                        data-confirm-label="Delete">
                                    <i class="bi bi-trash"></i>
                                </button>
                            }
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
