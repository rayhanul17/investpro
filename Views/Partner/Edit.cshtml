@model Partner
@{
    var isNew = ViewData["IsNew"] as bool? ?? Model.Id == Guid.Empty;
    ViewData["Title"] = isNew ? "New Partner" : "Edit Partner";
    Layout = "_AdminLayout";
    var formAction = isNew ? "/admin/investpro/partners/create" : $"/admin/investpro/partners/{Model.Id}/edit";
}

<div class="d-flex align-items-center mb-3 gap-2">
    <a asp-action="Index" class="btn btn-sm btn-outline-secondary">← Back</a>
    <h4 class="mb-0">@ViewData["Title"]</h4>
</div>

<form method="post" action="@formAction">
    @Html.AntiForgeryToken()
    <div asp-validation-summary="ModelOnly" class="alert alert-danger" role="alert"></div>

    <div class="card shadow-sm mb-3">
        <div class="card-header"><strong>Basic Info</strong></div>
        <div class="card-body">
            <div class="row g-3">
                <div class="col-md-6">
                    <label asp-for="Name" class="form-label">Name <span class="text-danger">*</span></label>
                    <input asp-for="Name" class="form-control" required />
                    <span asp-validation-for="Name" class="text-danger small"></span>
                </div>
                <div class="col-md-3">
                    <label asp-for="Phone" class="form-label">Phone</label>
                    <input asp-for="Phone" class="form-control" />
                </div>
                <div class="col-md-3">
                    <label asp-for="Email" class="form-label">Email</label>
                    <input asp-for="Email" class="form-control" type="email" />
                    <span asp-validation-for="Email" class="text-danger small"></span>
                </div>
                <div class="col-md-4">
                    <label asp-for="Nid" class="form-label">NID</label>
                    <input asp-for="Nid" class="form-control" />
                </div>
                <div class="col-md-8">
                    <label asp-for="Address" class="form-label">Address</label>
                    <input asp-for="Address" class="form-control" />
                </div>
            </div>
        </div>
    </div>

    <div class="card shadow-sm mb-3">
        <div class="card-header"><strong>Payout Channels</strong></div>
        <div class="card-body">
            <div class="row g-3">
                <div class="col-md-4">
                    <label asp-for="BankName" class="form-label">Bank Name</label>
                    <input asp-for="BankName" class="form-control" />
                </div>
                <div class="col-md-4">
                    <label asp-for="BankAccountNo" class="form-label">Bank Account No</label>
                    <input asp-for="BankAccountNo" class="form-control" />
                </div>
                <div class="col-md-4">
                    <label asp-for="MfsProvider" class="form-label">MFS Provider</label>
                    <select asp-for="MfsProvider" class="form-select">
                        <option value="">— None —</option>
                        <option value="bKash">bKash</option>
                        <option value="Nagad">Nagad</option>
                        <option value="Rocket">Rocket</option>
                        <option value="Upay">Upay</option>
                    </select>
                </div>
                <div class="col-md-4">
                    <label asp-for="MfsNumber" class="form-label">MFS Number</label>
                    <input asp-for="MfsNumber" class="form-control" />
                </div>
            </div>
        </div>
    </div>

    <div class="card shadow-sm mb-3">
        <div class="card-header"><strong>Nominee</strong></div>
        <div class="card-body">
            <div class="row g-3">
                <div class="col-md-4">
                    <label asp-for="NomineeName" class="form-label">Name</label>
                    <input asp-for="NomineeName" class="form-control" />
                </div>
                <div class="col-md-4">
                    <label asp-for="NomineePhone" class="form-label">Phone</label>
                    <input asp-for="NomineePhone" class="form-control" />
                </div>
                <div class="col-md-4">
                    <label asp-for="NomineeRelation" class="form-label">Relation</label>
                    <input asp-for="NomineeRelation" class="form-control" placeholder="e.g. Spouse, Brother" />
                </div>
            </div>
        </div>
    </div>

    <div class="card shadow-sm mb-3">
        <div class="card-body">
            <div class="mb-3">
                <label asp-for="Notes" class="form-label">Notes</label>
                <textarea asp-for="Notes" class="form-control" rows="3"></textarea>
            </div>
            <div class="form-check">
                <input asp-for="IsActive" class="form-check-input" />
                <label asp-for="IsActive" class="form-check-label">Active</label>
            </div>
        </div>
    </div>

    <div class="mt-3">
        <button type="submit" class="btn btn-primary">@(isNew ? "Create" : "Save Changes")</button>
        <a asp-action="Index" class="btn btn-outline-secondary ms-2">Cancel</a>
    </div>
</form>
