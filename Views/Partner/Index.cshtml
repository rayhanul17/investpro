@model List<Partner>
@{
    ViewData["Title"] = "Partners";
    Layout = "_InvestProLayout";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <div>
        <h4 class="mb-0">Partners (Shorik)</h4>
        <small class="text-muted">Global pool of investment partners — reusable across investments.</small>
    </div>
    <a asp-action="Create" class="btn btn-primary btn-sm">
        <i class="bi bi-plus-lg"></i> New Partner
    </a>
</div>

@if (TempData["Success"] is string ok)
{
    <div class="alert alert-success py-2">@ok</div>
}

<div class="card shadow-sm">
    <div class="card-body p-0">
        <table class="table table-hover mb-0 align-middle">
            <thead class="table-light">
                <tr>
                    <th>Name</th>
                    <th>Phone</th>
                    <th>Email</th>
                    <th>NID</th>
                    <th>Status</th>
                    <th class="text-end" style="width:160px">Actions</th>
                </tr>
            </thead>
            <tbody>
                @if (!Model.Any())
                {
                    <tr><td colspan="6" class="text-center text-muted py-4">No partners yet. Click <strong>New Partner</strong> to add one.</td></tr>
                }
                @foreach (var p in Model)
                {
                    <tr data-row-id="@p.Id">
                        <td class="fw-medium">@p.Name</td>
                        <td>@(p.Phone ?? "—")</td>
                        <td>@(p.Email ?? "—")</td>
                        <td>@(p.Nid ?? "—")</td>
                        <td>
                            @if (p.IsActive)
                            {
                                <span class="badge text-bg-success">Active</span>
                            }
                            else
                            {
                                <span class="badge text-bg-secondary">Inactive</span>
                            }
                        </td>
                        <td class="text-end">
                            <a asp-action="Edit" asp-route-id="@p.Id" class="btn btn-sm btn-outline-secondary">
                                <i class="bi bi-pencil"></i>
                            </a>
                            <button type="button" class="btn btn-sm btn-outline-danger"
                                    data-fcms-action="delete"
                                    data-url="/investpro/admin/partners/@p.Id/delete"
                                    data-confirm-title="Delete partner?"
                                    data-confirm-message="@p.Name"
                                    data-confirm-variant="danger"
                                    data-confirm-label="Delete">
                                <i class="bi bi-trash"></i>
                            </button>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
